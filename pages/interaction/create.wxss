.page-container { padding: 20rpx; background: #f5f5f5; min-height: 100vh; }
.form-card { background: #fff; border-radius: 16rpx; padding: 24rpx; }
.section-title { font-size: 30rpx; font-weight: bold; color: #333; margin-top: 24rpx; margin-bottom: 16rpx; display: block; }
.type-selector { display: flex; gap: 20rpx; }
.type-item { flex: 1; text-align: center; padding: 20rpx; border-radius: 12rpx; background: #f5f5f5; font-size: 28rpx; color: #666; }
.type-item.active { background: #FF6B6B; color: #fff; }
.input { border: 1rpx solid #eee; border-radius: 8rpx; padding: 16rpx; font-size: 28rpx; background: #fafafa; }
.textarea { border: 1rpx solid #eee; border-radius: 8rpx; padding: 16rpx; font-size: 28rpx; background: #fafafa; height: 160rpx; width: 100%; box-sizing: border-box; }
.options-box { margin-bottom: 20rpx; }
.option-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 12rpx; }
.option-input { flex: 1; }
.remove-btn { color: #FF6B6B; font-size: 26rpx; white-space: nowrap; }
.add-btn { text-align: center; color: #4D96F2; font-size: 28rpx; padding: 16rpx; }
.submit-btn { margin-top: 40rpx; background: #FF6B6B; color: #fff; text-align: center; padding: 24rpx; border-radius: 12rpx; font-size: 32rpx; }
.submit-btn.disabled { opacity: 0.6; }
