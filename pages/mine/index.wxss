/* mine.wxss */
.page-container {
  min-height: 100vh;
  background-color: #F8F9FA;
}

.header {
  background: linear-gradient(135deg, #FF6B6B 0%, #4ECDC4 100%);
  padding: 80rpx 32rpx 64rpx;
  text-align: center;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  margin: 0 auto 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-icon {
  font-size: 80rpx;
}

.username {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stats-card {
  margin: -40rpx 32rpx 32rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.1);
}

.stats-row {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #2D3436;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #636E72;
}

.divider {
  width: 2rpx;
  background: #E5E6EB;
}

.menu-list {
  background: #fff;
  border-radius: 16rpx;
  margin: 0 32rpx 32rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.menu-item {
  height: 96rpx;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  border-bottom: 1rpx solid #F2F3F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 24rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #2D3436;
}

.menu-arrow {
  font-size: 24rpx;
  color: #B2BEC3;
}

.version-info {
  text-align: center;
  padding: 32rpx;
  font-size: 22rpx;
  color: #B2BEC3;
}
